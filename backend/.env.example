# Server Configuration
PORT=8080

# Database Configuration
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/fintrack
DB_NAME=fintrack

# JWT Configuration
JWT_SECRET=change-this-to-a-random-secure-secret-key-min-32-chars
JWT_ACCESS_EXP=15
JWT_REFRESH_EXP=30

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# VAPID Keys for Push Notification (optional for now)
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
