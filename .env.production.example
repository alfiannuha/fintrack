# Production Environment Variables for FinTrack PWA

# ============================================
# BACKEND (Railway)
# ============================================

# Server Configuration
PORT=8080
GIN_MODE=release

# Database Configuration
# Get from MongoDB Atlas: https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/fintrack_prod?retryWrites=true&w=majority
DB_NAME=fintrack_prod

# JWT Configuration
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long

# Token Expiration
JWT_ACCESS_EXP=15
JWT_REFRESH_EXP=30

# CORS Configuration
# Replace with your Vercel domain
CORS_ORIGIN=https://fintrack-your-username.vercel.app

# VAPID Keys for Push Notifications (Optional)
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=

# ============================================
# FRONTEND (Vercel)
# ============================================

# Backend API URL
# Replace with your Railway domain
NEXT_PUBLIC_API_URL=https://your-backend-url.railway.app/api/v1

# VAPID Public Key (Optional)
NEXT_PUBLIC_VAPID_KEY=your-vapid-public-key

# OCR.space API Key (get from https://ocr.space/ocrapi)
NEXT_PUBLIC_OCR_SPACE_API_KEY=your-ocr-api-key

# Mindee API Key (get from https://mindee.com) - More accurate for receipts
NEXT_PUBLIC_MINDEE_API_KEY=your-mindee-api-key

# ============================================
# DEPLOYMENT CHECKLIST
# ============================================
# 1. Generate JWT_SECRET: openssl rand -base64 32
# 2. Get MONGO_URI from MongoDB Atlas
# 3. Deploy backend to Railway
# 4. Get Railway URL
# 5. Deploy frontend to Vercel
# 6. Get Vercel URL
# 7. Update CORS_ORIGIN with Vercel URL
# 8. Update NEXT_PUBLIC_API_URL with Railway URL
# 9. Redeploy both services
# 10. Test full flow
